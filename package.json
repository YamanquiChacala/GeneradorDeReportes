{
  "name": "montessori-school-report-generator",
  "description": "A simple GAS tool to help my school create student reports.",
  "version": "0.1.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@gas-plugin/unplugin": "^0.1.2",
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage && node append-theme.cjs",
    "build": "npm run test && node build.mjs",
    "push": "npm run build && clasp push",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  }
}
