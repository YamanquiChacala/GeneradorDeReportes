{
  "timeZone": "America/Mazatlan",
  "dependencies": {
    "enabledAdvancedServices": [
      {
        "userSymbol": "Drive",
        "version": "v3",
        "serviceId": "drive"
      },
      {
        "userSymbol": "Sheets",
        "version": "v4",
        "serviceId": "sheets"
      }
    ]
  },
  "oauthScopes": [
    "https://www.googleapis.com/auth/drive",
    "https://www.googleapis.com/auth/drive.file",
    "https://www.googleapis.com/auth/drive.addons.metadata.readonly",
    "https://www.googleapis.com/auth/script.external_request",
    "https://www.googleapis.com/auth/spreadsheets"
  ],
  "exceptionLogging": "STACKDRIVER",
  "runtimeVersion": "V8",
  "urlFetchWhitelist": [],
  "addOns": {
    "common": {
      "name": "📋 Sistema de Reportes",
      "logoUrl": "https://media.githubusercontent.com/media/YamanquiChacala/GeneradorDeReportes/refs/heads/main/images/spiral_32.png",
      "layoutProperties": {
        "primaryColor": "#0b5394"
      }
    },
    "drive": {
      "onItemsSelectedTrigger": {
        "runFunction": "buildDriveCard"
      },
      "homepageTrigger": {
        "runFunction": "buildDriveCard"
      }
    },
    "sheets": {
      "homepageTrigger": {
        "enabled": true,
        "runFunction": "buildSheetsCard"
      },
      "onFileScopeGrantedTrigger": {
        "runFunction": "buildSheetsCard"
      }
    }
  }
}